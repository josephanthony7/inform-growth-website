---
// TestimonialCarousel.astro
// High-impact testimonial showcase - marketing best practices
// Big metrics, large photos, clear social proof
---

<section class="testimonial-section">
  <div class="container">
    <div class="testimonial-card">
      <div class="carousel-track">

        <!-- Slide 1: Sylva -->
        <div class="carousel-slide active" data-slide="0">
          <div class="slide-inner">
            <!-- Hero Metric - First thing visitors see -->
            <div class="hero-metric">
              <span class="hero-metric-value">75%</span>
              <span class="hero-metric-label">Cost Reduction</span>
            </div>

            <!-- Main Content -->
            <div class="slide-main">
              <div class="slide-logo">
                <img src="/clients/sylva_logo.svg" alt="Sylva" />
              </div>
              <h2 class="slide-headline">
                "We consolidated 7 CRMs into one and cut costs by 75%"
              </h2>
              <div class="slide-context">
                Sylva unified their entire revenue operation - 400K+ records migrated with zero data loss.
              </div>
              <a href="/case-studies/sylva" class="slide-cta">
                Read the Full Story <span aria-hidden="true">→</span>
              </a>
            </div>

            <!-- Person - Large & Prominent -->
            <div class="slide-person">
              <div class="person-photo">
                <img src="/headshots/scott-sylva.jpg" alt="Scott from Sylva" />
              </div>
              <div class="person-info">
                <span class="person-name">Scott</span>
                <span class="person-title">Head of Operations</span>
                <span class="person-company">Sylva</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Slide 2: Revenue Accelerator -->
        <div class="carousel-slide" data-slide="1">
          <div class="slide-inner">
            <div class="hero-metric">
              <span class="hero-metric-value">3M+</span>
              <span class="hero-metric-label">Contacts Unified</span>
            </div>

            <div class="slide-main">
              <div class="slide-logo">
                <img src="/clients/revenue_accelerator_logo_new-removebg-preview.png" alt="Revenue Accelerator" />
              </div>
              <h2 class="slide-headline">
                "3 million contacts unified into one source of truth"
              </h2>
              <div class="slide-context">
                Revenue Accelerator eliminated duplicate records and reduced data costs by 40%.
              </div>
              <a href="/case-studies/revenue-accelerator-data-consolidation" class="slide-cta">
                Read the Full Story <span aria-hidden="true">→</span>
              </a>
            </div>

            <div class="slide-person">
              <div class="person-photo">
                <img src="/headshots/christi-revenue-accelerator.jpg" alt="Christi from Revenue Accelerator" />
              </div>
              <div class="person-info">
                <span class="person-name">Christi</span>
                <span class="person-title">Founder</span>
                <span class="person-company">Revenue Accelerator</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Slide 3: Women Travel Abroad -->
        <div class="carousel-slide" data-slide="2">
          <div class="slide-inner">
            <div class="hero-metric">
              <span class="hero-metric-value">27%</span>
              <span class="hero-metric-label">ROI Increase</span>
            </div>

            <div class="slide-main">
              <div class="slide-logo">
                <img src="/clients/WTA-Logo-High-Vis-removebg-preview.png" alt="Women Travel Abroad" />
              </div>
              <h2 class="slide-headline">
                "Now we see exactly which partners drive real revenue"
              </h2>
              <div class="slide-context">
                Women Travel Abroad built their first partner-level attribution system.
              </div>
              <a href="/case-studies/women-travel-abroad" class="slide-cta">
                Read the Full Story <span aria-hidden="true">→</span>
              </a>
            </div>

            <div class="slide-person">
              <div class="person-photo">
                <img src="/headshots/katherine-wta.jpg" alt="Katherine from Women Travel Abroad" />
              </div>
              <div class="person-info">
                <span class="person-name">Katherine</span>
                <span class="person-title">Founder</span>
                <span class="person-company">Women Travel Abroad</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Navigation dots -->
      <div class="carousel-nav">
        <button class="carousel-dot active" data-slide="0" aria-label="Go to slide 1"></button>
        <button class="carousel-dot" data-slide="1" aria-label="Go to slide 2"></button>
        <button class="carousel-dot" data-slide="2" aria-label="Go to slide 3"></button>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-section {
    padding: var(--space-lg) 0 var(--space-xl);
    background-color: var(--color-bg-base);
  }

  .testimonial-section .container {
    max-width: 1400px;
  }

  .testimonial-card {
    background-color: var(--navy);
    border-radius: 20px;
    padding: var(--space-xl);
    border: 1px solid rgba(45, 80, 22, 0.3);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .testimonial-card {
      padding: var(--space-2xl) var(--space-3xl);
    }
  }

  .carousel-track {
    position: relative;
    height: 520px;
    display: flex;
    align-items: center;
  }

  @media (min-width: 900px) {
    .carousel-track {
      height: 280px;
    }
  }

  .carousel-slide {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease;
  }

  .carousel-slide.active {
    opacity: 1;
    visibility: visible;
  }

  .slide-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 900px) {
    .slide-inner {
      grid-template-columns: 100px 1fr 240px;
      gap: var(--space-2xl);
    }
  }

  /* Hero Metric - Clean, no box */
  .hero-metric {
    text-align: center;
    padding: var(--space-sm) 0;
  }

  .hero-metric-value {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: #FFFFFF;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .hero-metric-value {
      font-size: 3rem;
    }
  }

  .hero-metric-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.6);
    margin-top: var(--space-1);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Main Content */
  .slide-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .slide-logo {
    height: 32px;
  }

  .slide-logo img {
    height: 32px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.8;
  }

  .slide-headline {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: #FFFFFF;
    line-height: 1.3;
    margin: 0;
  }

  @media (min-width: 768px) {
    .slide-headline {
      font-size: var(--text-2xl);
    }
  }

  .slide-context {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }

  .slide-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #FFFFFF;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: all var(--transition-fast);
    margin-top: var(--space-sm);
  }

  .slide-cta:hover {
    gap: var(--space-3);
  }

  .slide-cta span {
    transition: transform var(--transition-fast);
  }

  .slide-cta:hover span {
    transform: translateX(4px);
  }

  /* Person - Large & Prominent */
  .slide-person {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
  }

  .person-photo {
    width: 180px;
    height: 180px;
    border-radius: 12px;
    overflow: hidden;
    border: 3px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  @media (min-width: 768px) {
    .person-photo {
      width: 220px;
      height: 220px;
    }
  }

  .person-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
  }

  .person-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .person-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: #FFFFFF;
  }

  .person-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
  }

  .person-company {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: #FFFFFF;
  }

  /* Navigation dots */
  .carousel-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-xl);
  }

  .carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.3);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    padding: 0;
  }

  .carousel-dot:hover {
    background-color: rgba(255, 255, 255, 0.5);
    transform: scale(1.1);
  }

  .carousel-dot.active {
    background-color: #FFFFFF;
    transform: scale(1.2);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.carousel-slide');
    const dots = document.querySelectorAll('.carousel-dot');
    let currentSlide = 0;
    let autoplayInterval: ReturnType<typeof setInterval>;

    function showSlide(index: number) {
      slides.forEach(slide => slide.classList.remove('active'));
      dots.forEach(dot => dot.classList.remove('active'));

      slides[index]?.classList.add('active');
      dots[index]?.classList.add('active');
      currentSlide = index;
    }

    function nextSlide() {
      const next = (currentSlide + 1) % slides.length;
      showSlide(next);
    }

    // Click handlers for dots
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        showSlide(index);
        resetAutoplay();
      });
    });

    // Autoplay - 8 seconds per slide
    function startAutoplay() {
      autoplayInterval = setInterval(nextSlide, 8000);
    }

    function resetAutoplay() {
      clearInterval(autoplayInterval);
      startAutoplay();
    }

    startAutoplay();

    // Pause on hover
    const carousel = document.querySelector('.testimonial-card');
    carousel?.addEventListener('mouseenter', () => clearInterval(autoplayInterval));
    carousel?.addEventListener('mouseleave', startAutoplay);
  });
</script>
